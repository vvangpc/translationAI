{
  "manifest_version": 3,
  "name": "喵喵翻译",
  "version": "0.2.0",
  "description": "喵喵翻译 🐱 轻量自用翻译扩展：划词气泡 / 右键菜单 / 整页双语对照，支持 LLM (OpenAI 兼容) 与 Google 翻译",
  "permissions": ["storage", "contextMenus", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "喵喵翻译",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/selection-bubble.js",
        "content/fullpage.js",
        "content/content.js"
      ],
      "css": ["content/styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "translate-selection": {
      "suggested_key": { "default": "Alt+T" },
      "description": "喵喵翻译：翻译选中文本"
    },
    "translate-page": {
      "suggested_key": { "default": "Alt+A" },
      "description": "喵喵翻译：整页翻译 / 切换显示译文"
    }
  }
}
